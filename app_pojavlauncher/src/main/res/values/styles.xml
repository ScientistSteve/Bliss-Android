<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light or not? -->
    <style name="AppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:fontFamily">@font/outfit</item>
        <item name="fontFamily">@font/outfit</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorAccent">@color/copper_highlight</item>
        <item name="colorControlActivated">@color/copper_primary</item>
        <item name="colorControlNormal">@color/copper_text_muted</item>
        <item name="android:textColorPrimary">@color/copper_text</item>
        <item name="android:textColorSecondary">@color/copper_text_muted</item>
        <item name="preferenceTheme">@style/CopperPreferenceTheme</item>

        <item name="android:textSize">@dimen/_12ssp</item>

    </style>

    <style name="LauncherFragment_Divider">
        <item name="android:layout_width">@dimen/padding_tiny</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="LauncherMenuButton" parent="Widget.AppCompat.Button">
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="LauncherMenuButton.Universal" parent="LauncherMenuButton">
        <item name="android:layout_height">@dimen/_66sdp</item>
    </style>

    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">?android:attr/listDivider</item>
    </style>

    <item name="dimension_tracker" type="id" />
    <style name="DimensionTracker">
        <item name="android:id">@id/dimension_tracker</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>


    <style name="CopperPreferenceTheme" parent="PreferenceThemeOverlay.v14.Material">
        <item name="android:fontFamily">@font/outfit</item>
        <item name="fontFamily">@font/outfit</item>
        <item name="android:colorAccent">@color/copper_highlight</item>
        <item name="colorAccent">@color/copper_highlight</item>
    </style>
</resources>
