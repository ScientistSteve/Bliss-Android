<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <View android:id="@+id/accent_preview_swatch" android:layout_width="match_parent" android:layout_height="40dp" />
    <SeekBar android:id="@+id/seek_red" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="255"/>
    <SeekBar android:id="@+id/seek_green" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="255"/>
    <SeekBar android:id="@+id/seek_blue" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="255"/>
</LinearLayout>
