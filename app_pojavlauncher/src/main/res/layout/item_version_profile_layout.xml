<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/_12sdp"
    android:paddingEnd="@dimen/_12sdp">

    <TextView
        android:id="@+id/version_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/outfit"
        android:paddingStart="@dimen/_4sdp"
        android:paddingTop="@dimen/_10sdp"
        android:paddingBottom="@dimen/_6sdp"
        android:textColor="@color/copper_highlight"
        android:textSize="@dimen/_11ssp"
        android:textStyle="bold"
        tools:text="Vanilla" />

    <LinearLayout
        android:id="@+id/version_row"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_64sdp"
        android:background="@drawable/bg_copper_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/_14sdp"
        android:paddingEnd="@dimen/_12sdp">

        <ImageView
            android:id="@+id/version_icon"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            android:scaleType="fitCenter"
            tools:src="@drawable/ic_gamepad_pointer" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_12sdp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/version_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/outfit"
                android:maxLines="1"
                android:textColor="@color/copper_text"
                android:textSize="@dimen/_15ssp"
                android:textStyle="bold"
                tools:text="1.21.4" />

            <TextView
                android:id="@+id/version_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_3sdp"
                android:fontFamily="@font/outfit"
                android:textColor="@color/copper_text_muted"
                android:textSize="@dimen/_11ssp"
                tools:text="Vanilla" />
        </LinearLayout>

        <ImageView
            android:id="@+id/version_download_icon"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:src="@drawable/ic_download_copper" />
    </LinearLayout>
</LinearLayout>
