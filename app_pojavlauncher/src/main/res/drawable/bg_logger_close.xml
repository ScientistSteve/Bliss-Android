<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape
            android:shape="ring"
            android:innerRadius="20dp"
            android:thickness="2dp"
            android:useLevel="false">
            <gradient
                android:angle="45"
                android:endColor="#CCFFB300"
                android:startColor="#CCFF6B00" />
        </shape>
    </item>
    <item>
        <shape
            android:shape="ring"
            android:innerRadius="20dp"
            android:thickness="2dp"
            android:useLevel="false">
            <gradient
                android:angle="45"
                android:endColor="#FFFFB300"
                android:startColor="#FFFF6B00" />
        </shape>
    </item>
</selector>
