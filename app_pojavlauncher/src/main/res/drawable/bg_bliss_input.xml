<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/copper_surface" />
            <stroke android:width="2dp" android:color="@color/copper_highlight" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/copper_surface" />
            <stroke android:width="1dp" android:color="@color/copper_stroke" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
