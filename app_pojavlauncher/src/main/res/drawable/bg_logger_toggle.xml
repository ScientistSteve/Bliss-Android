<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="#FF2563EB" />
            <stroke android:width="1dp" android:color="#FF60A5FA" />
            <corners android:radius="16dp" />
            <padding android:left="14dp" android:top="8dp" android:right="14dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#FF1F2937" />
            <stroke android:width="1dp" android:color="#FF374151" />
            <corners android:radius="16dp" />
            <padding android:left="14dp" android:top="8dp" android:right="14dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>
